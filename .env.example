APP_NAME=leadership-insight-agent
DEBUG=true
LOG_LEVEL=DEBUG
LOG_FORMAT=console

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
ALLOWED_HOSTS=*
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

OPENAI_API_KEY=sk-change-me

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

QDRANT__URL=http://localhost:6333
QDRANT__COLLECTION=leadership_docs
QDRANT__API_KEY=

REDIS__URL=redis://localhost:6379/0
REDIS__TTL_SECONDS=3600

POSTGRES__HOST=localhost
POSTGRES__PORT=5432
POSTGRES__USER=leadership
POSTGRES__PASSWORD=leadership_dev_password
POSTGRES__DATABASE=leadership_agent

RAG__CHUNK_SIZE=512
RAG__CHUNK_OVERLAP=50
RAG__SIMILARITY_TOP_K=5
RAG__RERANK_TOP_N=3
RAG__RESPONSE_MODE=tree_summarize

SECURITY__RATE_LIMIT=20/minute
SECURITY__MAX_QUERY_LENGTH=2000
SECURITY__ENABLE_PII_MASKING=true
SECURITY__BLOCKED_PATTERNS=

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=leadership-insight-agent
PROMETHEUS_PORT=9464
